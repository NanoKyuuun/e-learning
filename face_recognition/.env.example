FLASK_DEBUG=False
FLASK_PORT=5000

# API Key untuk komunikasi internal dengan Laravel
# Wajib diganti dengan nilai yang aman di production
FACE_API_KEY=secret-internal-key

# Threshold jarak wajah (0.0 - 1.0)
# Semakin kecil = semakin ketat. Default 0.45 cukup untuk kebanyakan kasus
FACE_THRESHOLD=0.45

# Origins yang diizinkan mengakses API ini (pisahkan dengan koma)
# Karena ini internal service, sebaiknya hanya dari localhost
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8085,http://127.0.0.1:8000

# Batas ukuran file upload (dalam bytes). Default 10MB
MAX_CONTENT_LENGTH=10485760
